{
  "functions": {
    "api/ai.js": {
      "maxDuration": 30
    },
    "api/search.js": {
      "maxDuration": 30
    },
    "api/relay.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}

