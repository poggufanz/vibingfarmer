{
  "name": "vibing-farmer-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/assert-no-dev-dispatch.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\" \"api/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\" \"api/**/*.js\"",
    "pages:dev": "npm run build && wrangler pages dev",
    "pages:deploy": "npm run build && wrangler pages deploy",
    "build:ext": "vite build -c extension/vite.config.extension.js"
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.3.0",
    "@gsap/react": "^2.1.2",
    "@scure/bip39": "1.3.0",
    "@solana/kit": "^5.5.1",
    "@stellar/stellar-sdk": "^16.0.1",
    "@transak/ui-js-sdk": "^1.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@zerodev/passkey-validator": "^5.6.0",
    "@zerodev/permissions": "^5.6.3",
    "@zerodev/sdk": "^5.5.10",
    "dotenv": "^17.4.2",
    "ed25519-hd-key": "1.3.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "pixi.js": "^8.19.0",
    "qrcode": "1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "smart-account-kit": "0.2.10",
    "viem": "^2.54.3",
    "vite": "^5.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "16.3.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "29.1.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "vitest": "^2.1.9",
    "wrangler": "^4.0.0"
  }
}
