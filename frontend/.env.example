# Frontend env template — copy to frontend/.env.local (gitignored) and fill in.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Server-side AI key (NO VITE_ prefix) — read by the /api/ai proxy, never bundled to the client.
# OPTIONAL / host-funded. The app is BYOK-first: users paste their own Venice or
# DeepSeek key in Settings (per-tab sessionStorage). Set this ONLY if you want an
# out-of-the-box "host demo key" that anonymous visitors spend. LEAVE IT UNSET for a
# lockdown deploy — /api/ai then 503s and the app uses the deterministic fallback,
# so no stranger can drain your key.
DEEPSEEK_API_KEY=sk-your_deepseek_key

# Tavily web search — live DeFi market context injected into the Venice AI strategy prompt.
# Server-side key (NO VITE_ prefix) — read by the /api/search proxy, never bundled to the client.
# OPTIONAL / host-funded, same BYOK model as DEEPSEEK_API_KEY: users can paste their
# own Tavily key in Settings (then the browser calls Tavily directly). If this is unset
# AND the user set no key, market search 503s/skips and strategy falls back to static
# knowledge only. Leave unset for a lockdown deploy.
TAVILY_API_KEY=tvly-...

# About section links (Settings → About). Optional — fall back to "#" if unset.
VITE_GITHUB_URL=https://github.com/your-org/vibing-farmer

# Security: allowed origin for /api/ai proxy
# Set to your Vercel deployment URL after deploy
ALLOWED_ORIGIN=https://your-app.vercel.app

# ─── Soroban gasless relay (sub-project 2) ───
# Relayer keypair SECRET (S...). Server-only — never expose to the client bundle.
# Generate + fund on testnet:  stellar keys generate relayer --network testnet --fund
# then read the secret with:    stellar keys show relayer
STELLAR_RELAYER_SECRET=S...
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_VAULT_ADDRESS=CB5VKYDUIYX3RZWGVLKKNBPG7V7Z5JIHF2QPNQKWKAHVA3IPSLFZJDYU

# funding_router for the one-popup grant flow; unset = router relaying disabled
# (relay then sponsors only router.grant / router.pull on this exact contract)
SOROBAN_ROUTER_ADDRESS=CBEI5VJKKWLXKQUUUETBAPZSQQLH7I57TSIDTMV4WJMBKIGVF7NSNOFY

# Agents the relay will sponsor F11 exit-leg-2 token.transfer calls for (comma-separated,
# exact match, fail-closed if empty). Demo agent + your local smoke agent (SMOKE_AGENT_ADDRESS):
SOROBAN_AGENT_ALLOWLIST=CCY452UMBSDG4VHHECJAW3T5Q5BUK5NJUK22IDI2MQBHAZLTIM256UAC,C...

# Testnet token faucet (server-only; leave unset to disable /api/faucet with 503)
VF_FAUCET_SECRET=S...                    # vf-deployer secret; treasury must hold testnet Blend USDC
SOROBAN_TOKEN_ADDRESS=CAQCFVLOBK5GIULPNZRGATJJMIZL5BSP7X5YJVMGCPTUEPFM4AVSRCJU

# ─── VF API gate (SEP-10 portal + gateway) ───
VF_AUTH_SIGNING_KEY=S...        # server SEP-10 signing keypair secret (testnet)
VF_JWT_SECRET=change-me-32-chars-min
VF_HOME_DOMAIN=localhost:5173   # SEP-10 home_domain / web_auth_domain
VF_GLOBAL_DAILY_CAP=5000        # global upstream budget per scope per day

# --- Approach C / SP3: Base cross-chain leg ---
# ZeroDev dashboard project (Base Sepolia app). Client-embeddable by ZeroDev's own design (the
# project ID alone grants no secret access) — still worth restricting to your deployed domain
# in the dashboard. See docs/deploy-checklist.md.
VITE_ZERODEV_PROJECT_ID=
# ZeroDev passkey server URL (dashboard → Passkeys). Brokers the Base owner's WebAuthn ceremony —
# separate from the Stellar passkey, which needs no such server. See docs/deploy-checklist.md.
VITE_ZERODEV_PASSKEY_SERVER_URL=
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# SP1 deliverable — set after base-contracts/ is deployed (deployments/base-sepolia.json).
VITE_YIELD_ROUTER_ADDRESS=
# Whitelisted Base pools (ERC-4626), same source. Add more VITE_BASE_POOL_N_ADDRESS as needed.
VITE_BASE_POOL_1_ADDRESS=
VITE_BASE_POOL_2_ADDRESS=
VITE_BASE_POOL_3_ADDRESS=
# SP2 relayer HTTP base (absolute origin if it runs off-origin; relative /api/vf-cross otherwise).
VITE_CROSS_RELAYER_BASE=

# ─── On-ramp widget (SP4) — Transak, delivers USDC directly to Stellar ───
# Server-only — never expose to the client bundle. Read by /api/onramp-session.
# Get keys from the Transak Partner Dashboard: https://dashboard.transak.com
TRANSAK_API_KEY=your_transak_api_key
TRANSAK_ACCESS_TOKEN=your_transak_access_token
TRANSAK_ENVIRONMENT=STAGING
TRANSAK_REFERRER_DOMAIN=localhost

