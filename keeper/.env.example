# keeper/.env.example — copy to keeper/.dev.vars (gitignored) and fill in real values.

# ---- Lifeboat radar (node --env-file=.dev.vars src/radar-runner.mjs) ----
LIFEBOAT_UTIL_ENGAGE_BPS=9500
LIFEBOAT_UTIL_RESUME_BPS=8500
LIFEBOAT_LIQ_DROP_ENGAGE_BPS=3000
LIFEBOAT_ORACLE_DIV_ENGAGE_BPS=2500
LIFEBOAT_ORACLE_DIV_RESUME_BPS=500
LIFEBOAT_ALL_CLEAR_LEDGERS=100
# demo: LIFEBOAT_ALL_CLEAR_LEDGERS=10
POOL_ORACLE=            # Blend pool oracle contract (empty = oracle detector off)
LIFEBOAT_REF_PRICE=     # static reference price, demo mock (e.g. 1.0)
LIFEBOAT_REF_URLS=      # comma-separated JSON endpoints returning {"price": n}
